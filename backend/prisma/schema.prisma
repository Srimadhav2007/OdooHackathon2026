// This is your Prisma schema file
// Run: npx prisma migrate dev --name init
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  EMPLOYEE
  DEPT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  TRANSFER_REQUESTED
  TRANSFERRED
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum AuditVerdict {
  VERIFIED
  MISSING
  DAMAGED
}

enum NotificationType {
  ASSET_ASSIGNED
  ASSET_RETURNED
  MAINTENANCE_RAISED
  MAINTENANCE_APPROVED
  MAINTENANCE_REJECTED
  MAINTENANCE_RESOLVED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  TRANSFER_REQUESTED
  TRANSFER_APPROVED
  TRANSFER_REJECTED
  OVERDUE_RETURN
  AUDIT_ASSIGNED
  AUDIT_DISCREPANCY
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model Department {
  id              BigInt           @id @default(autoincrement())
  name            String           @unique
  status          DepartmentStatus @default(ACTIVE)
  parentId        BigInt?          @map("parent_id")
  parent          Department?      @relation("DeptHierarchy", fields: [parentId], references: [id])
  children        Department[]     @relation("DeptHierarchy")
  headId          BigInt?          @unique @map("head_id")
  head            Employee?        @relation("DeptHead", fields: [headId], references: [id])
  employees       Employee[]       @relation("DeptEmployees")
  allocations     Allocation[]
  auditCycles     AuditCycle[]
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("department")
}

model Employee {
  id                  BigInt          @id @default(autoincrement())
  name                String
  email               String          @unique
  passwordHash        String          @map("password_hash")
  role                Role            @default(EMPLOYEE)
  status              EmployeeStatus  @default(ACTIVE)
  departmentId        BigInt?         @map("department_id")
  department          Department?     @relation("DeptEmployees", fields: [departmentId], references: [id])
  headOfDepartment    Department?     @relation("DeptHead")
  allocations         Allocation[]
  bookings            Booking[]
  maintenanceRaised   MaintenanceRequest[] @relation("RaisedBy")
  maintenanceApproved MaintenanceRequest[] @relation("ApprovedBy")
  maintenanceTech     MaintenanceRequest[] @relation("Technician")
  auditAssignments    AuditAssignment[]
  auditResults        AuditResult[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
  transfersRequested  TransferRequest[] @relation("TransferRequester")
  transfersApproved   TransferRequest[] @relation("TransferApprover")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  @@map("employee")
}

model AssetCategory {
  id           BigInt   @id @default(autoincrement())
  name         String   @unique
  description  String?
  customFields Json?    @map("custom_fields") // e.g. { "warrantyPeriod": "text", "voltage": "number" }
  assets       Asset[]
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("asset_category")
}

model Asset {
  id              BigInt        @id @default(autoincrement())
  tag             String        @unique  // AF-0001, AF-0002, ...
  name            String
  categoryId      BigInt        @map("category_id")
  category        AssetCategory @relation(fields: [categoryId], references: [id])
  serialNumber    String?       @map("serial_number")
  acquisitionDate DateTime?     @map("acquisition_date")
  acquisitionCost Decimal?      @db.Decimal(12, 2) @map("acquisition_cost")
  condition       AssetCondition @default(GOOD)
  status          AssetStatus   @default(AVAILABLE)
  location        String?
  isBookable      Boolean       @default(false) @map("is_bookable")
  photoUrl        String?       @map("photo_url")
  documents       Json?         // array of { name, url }
  customValues    Json?         @map("custom_values") // matches category.customFields keys
  allocations     Allocation[]
  bookings        Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditResults    AuditResult[]
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("asset")
}

model Allocation {
  id               BigInt           @id @default(autoincrement())
  assetId          BigInt           @map("asset_id")
  asset            Asset            @relation(fields: [assetId], references: [id])
  employeeId       BigInt?          @map("employee_id")
  employee         Employee?        @relation(fields: [employeeId], references: [id])
  departmentId     BigInt?          @map("department_id")
  department       Department?      @relation(fields: [departmentId], references: [id])
  status           AllocationStatus @default(ACTIVE)
  expectedReturn   DateTime?        @map("expected_return")
  actualReturn     DateTime?        @map("actual_return")
  conditionNotes   String?          @map("condition_notes")
  transferRequest  TransferRequest?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@map("allocation")
}

model TransferRequest {
  id             BigInt         @id @default(autoincrement())
  allocationId   BigInt         @unique @map("allocation_id")
  allocation     Allocation     @relation(fields: [allocationId], references: [id])
  requestedById  BigInt         @map("requested_by_id")
  requestedBy    Employee       @relation("TransferRequester", fields: [requestedById], references: [id])
  targetEmployeeId BigInt?      @map("target_employee_id")
  targetDeptId     BigInt?      @map("target_dept_id")
  reason         String?
  status         TransferStatus @default(PENDING)
  approvedById   BigInt?        @map("approved_by_id")
  approvedBy     Employee?      @relation("TransferApprover", fields: [approvedById], references: [id])
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("transfer_request")
}

model Booking {
  id         BigInt        @id @default(autoincrement())
  assetId    BigInt        @map("asset_id")
  asset      Asset         @relation(fields: [assetId], references: [id])
  userId     BigInt        @map("user_id")
  user       Employee      @relation(fields: [userId], references: [id])
  startTime  DateTime      @map("start_time")
  endTime    DateTime      @map("end_time")
  status     BookingStatus @default(UPCOMING)
  notes      String?
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  @@map("booking")
}

model MaintenanceRequest {
  id           BigInt              @id @default(autoincrement())
  assetId      BigInt              @map("asset_id")
  asset        Asset               @relation(fields: [assetId], references: [id])
  raisedById   BigInt              @map("raised_by_id")
  raisedBy     Employee            @relation("RaisedBy", fields: [raisedById], references: [id])
  priority     MaintenancePriority @default(MEDIUM)
  status       MaintenanceStatus   @default(PENDING)
  description  String
  photoUrl     String?             @map("photo_url")
  approvedById BigInt?             @map("approved_by_id")
  approvedBy   Employee?           @relation("ApprovedBy", fields: [approvedById], references: [id])
  technicianId BigInt?             @map("technician_id")
  technician   Employee?           @relation("Technician", fields: [technicianId], references: [id])
  resolvedAt   DateTime?           @map("resolved_at")
  resolution   String?
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@map("maintenance_request")
}

model AuditCycle {
  id           BigInt           @id @default(autoincrement())
  name         String
  scopeType    String           @map("scope_type") // "DEPARTMENT" | "LOCATION"
  departmentId BigInt?          @map("department_id")
  department   Department?      @relation(fields: [departmentId], references: [id])
  locationScope String?         @map("location_scope")
  startDate    DateTime         @map("start_date")
  endDate      DateTime         @map("end_date")
  status       AuditCycleStatus @default(OPEN)
  assignments  AuditAssignment[]
  results      AuditResult[]
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@map("audit_cycle")
}

model AuditAssignment {
  id        BigInt     @id @default(autoincrement())
  cycleId   BigInt     @map("cycle_id")
  cycle     AuditCycle @relation(fields: [cycleId], references: [id])
  auditorId BigInt     @map("auditor_id")
  auditor   Employee   @relation(fields: [auditorId], references: [id])
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("audit_assignment")
}

model AuditResult {
  id        BigInt       @id @default(autoincrement())
  cycleId   BigInt       @map("cycle_id")
  cycle     AuditCycle   @relation(fields: [cycleId], references: [id])
  assetId   BigInt       @map("asset_id")
  asset     Asset        @relation(fields: [assetId], references: [id])
  auditorId BigInt       @map("auditor_id")
  auditor   Employee     @relation(fields: [auditorId], references: [id])
  verdict   AuditVerdict
  notes     String?
  createdAt DateTime     @default(now()) @map("created_at")

  @@map("audit_result")
}

model Notification {
  id          BigInt           @id @default(autoincrement())
  recipientId BigInt           @map("recipient_id")
  recipient   Employee         @relation(fields: [recipientId], references: [id])
  type        NotificationType
  message     String
  isRead      Boolean          @default(false) @map("is_read")
  refId       BigInt?          @map("ref_id")
  refType     String?          @map("ref_type")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@map("notification")
}

model ActivityLog {
  id        BigInt   @id @default(autoincrement())
  actorId   BigInt   @map("actor_id")
  actor     Employee @relation(fields: [actorId], references: [id])
  action    String   // e.g. "ALLOCATED_ASSET", "RAISED_MAINTENANCE", "CLOSED_AUDIT"
  entity    String   // e.g. "ASSET", "BOOKING", "MAINTENANCE_REQUEST"
  entityId  BigInt   @map("entity_id")
  metadata  Json?    // extra context
  createdAt DateTime @default(now()) @map("created_at")

  @@map("activity_log")
}
