// This is your Prisma schema file
// Run: npx prisma migrate dev --name init
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS (Preserved from original schema, but models will use DB native types)
// ─────────────────────────────────────────────

enum Role {
  EMPLOYEE
  DEPT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum DepartmentStatus {
  ACTIVE
  INACTIVE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  TRANSFER_REQUESTED
  TRANSFERRED
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum AuditVerdict {
  VERIFIED
  MISSING
  DAMAGED
}

enum NotificationType {
  ASSET_ASSIGNED
  ASSET_RETURNED
  MAINTENANCE_RAISED
  MAINTENANCE_APPROVED
  MAINTENANCE_REJECTED
  MAINTENANCE_RESOLVED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  TRANSFER_REQUESTED
  TRANSFER_APPROVED
  TRANSFER_REJECTED
  OVERDUE_RETURN
  AUDIT_ASSIGNED
  AUDIT_DISCREPANCY
}

// ─────────────────────────────────────────────
// MODELS (Mapped to snake_case / lowercase and BigInt autoincrement IDs)
// ─────────────────────────────────────────────

model Department {
  id              BigInt            @id @default(autoincrement())
  name            String            @unique @db.VarChar(100)
  status          Boolean           @default(true)
  parentId        BigInt?           @map("parent_department_id")
  parent          Department?       @relation("DeptHierarchy", fields: [parentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  children        Department[]      @relation("DeptHierarchy")
  headId          BigInt?           @unique @map("head_employee_id")
  head            Employee?         @relation("DeptHead", fields: [headId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  employees       Employee[]        @relation("DeptEmployees")
  allocations     Allocation[]
  transfersTargeted TransferRequest[] @relation("TransferTargetDept")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  @@map("department")
}

model Employee {
  id                  BigInt               @id @default(autoincrement())
  name                String               @db.VarChar(100)
  email               String               @unique @db.VarChar(80)
  passwordHash        String               @map("password") @db.VarChar(255)
  role                String               @db.VarChar(20)
  status              Boolean              @default(true)
  departmentId        BigInt?              @map("department_id")
  department          Department?          @relation("DeptEmployees", fields: [departmentId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  headOfDepartment    Department?          @relation("DeptHead")
  allocations         Allocation[]
  bookings            Booking[]
  maintenanceRaised   MaintenanceRequest[] @relation("RaisedBy")
  maintenanceApproved MaintenanceRequest[] @relation("ApprovedBy")
  maintenanceTech     MaintenanceRequest[] @relation("Technician")
  auditAssignments    AuditAssignment[]
  auditResults        AuditResult[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
  transfersRequested  TransferRequest[]    @relation("TransferRequester")
  transfersApproved   TransferRequest[]    @relation("TransferApprover")
  transfersTargeted   TransferRequest[]    @relation("TransferTargetEmployee")
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  @@map("employee")
}

model AssetCategory {
  id           BigInt   @id @default(autoincrement())
  name         String   @unique @db.VarChar(100)
  description  String?  @db.Text
  customFields Json?    @map("custom_fields")
  assets       Asset[]
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("asset_category")
}

model Asset {
  id              BigInt               @id @default(autoincrement())
  tag             String               @unique @db.VarChar(50)
  name            String               @db.VarChar(150)
  categoryId      BigInt               @map("category_id")
  category        AssetCategory        @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  serialNumber    String?              @map("serial_number") @db.VarChar(100)
  acquisitionDate DateTime?            @map("acquisition_date") @db.Date
  acquisitionCost Decimal?             @map("acquisition_cost") @db.Decimal(12, 2)
  condition       String?              @db.VarChar(50)
  status          String               @db.VarChar(30)
  location        String?              @db.VarChar(100)
  isBookable      Boolean              @default(false) @map("is_bookable")
  photoUrl        String?              @map("photo_url") @db.Text
  documents       Json?                @map("documents")
  customValues    Json?                @map("custom_values")
  allocations     Allocation[]
  bookings        Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditResults    AuditResult[]
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime             @updatedAt @map("updated_at") @db.Timestamptz

  @@map("asset")
}

model Allocation {
  id               BigInt           @id @default(autoincrement())
  assetId          BigInt           @map("asset_id")
  asset            Asset            @relation(fields: [assetId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  employeeId       BigInt?          @map("employee_id")
  employee         Employee?        @relation(fields: [employeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  departmentId     BigInt?          @map("department_id")
  department       Department?      @relation(fields: [departmentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  status           String           @db.VarChar(30)
  expectedReturn   DateTime?        @map("expected_return") @db.Date
  actualReturn     DateTime?        @map("actual_return") @db.Date
  conditionNotes   String?          @map("condition_notes") @db.Text
  transferRequest  TransferRequest?
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  @@map("allocation")
}

model TransferRequest {
  id               BigInt      @id @default(autoincrement())
  allocationId     BigInt      @unique @map("allocation_id")
  allocation       Allocation  @relation(fields: [allocationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  requestedById    BigInt      @map("requested_by_id")
  requestedBy      Employee    @relation("TransferRequester", fields: [requestedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  targetEmployeeId BigInt?     @map("target_employee_id")
  targetEmployee   Employee?   @relation("TransferTargetEmployee", fields: [targetEmployeeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  targetDeptId     BigInt?     @map("target_department_id")
  targetDept       Department? @relation("TransferTargetDept", fields: [targetDeptId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reason           String?     @db.Text
  status           String      @db.VarChar(30)
  approvedById     BigInt?     @map("approved_by_id")
  approvedBy       Employee?   @relation("TransferApprover", fields: [approvedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  @@map("transfer_request")
}

model Booking {
  id         BigInt   @id @default(autoincrement())
  assetId    BigInt   @map("asset_id")
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId     BigInt   @map("user_id")
  user       Employee @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  startTime  DateTime @map("start_time") @db.Timestamptz
  endTime    DateTime @map("end_time") @db.Timestamptz
  status     String   @db.VarChar(30)
  notes      String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("booking")
}

model MaintenanceRequest {
  id           BigInt    @id @default(autoincrement())
  assetId      BigInt    @map("asset_id")
  asset        Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  raisedById   BigInt    @map("raised_by_id")
  raisedBy     Employee  @relation("RaisedBy", fields: [raisedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  priority     String    @db.VarChar(20)
  status       String    @db.VarChar(30)
  description  String    @db.Text
  photoUrl     String?   @map("photo_url") @db.Text
  approvedById BigInt?   @map("approved_by_id")
  approvedBy   Employee? @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  technicianId BigInt?   @map("technician_id")
  technician   Employee? @relation("Technician", fields: [technicianId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  resolvedAt   DateTime? @map("resolved_at") @db.Timestamptz
  resolution   String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@map("maintenance_request")
}

model AuditCycle {
  id          BigInt            @id @default(autoincrement())
  name        String            @db.VarChar(100)
  scopeType   String?           @map("scope_type") @db.VarChar(50)
  scopeValue  String?           @map("scope_value") @db.VarChar(100)
  startDate   DateTime          @map("start_date") @db.Date
  endDate     DateTime          @map("end_date") @db.Date
  status      String            @db.VarChar(30)
  assignments AuditAssignment[]
  results     AuditResult[]
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  @@map("audit_cycle")
}

model AuditAssignment {
  id        BigInt     @id @default(autoincrement())
  cycleId   BigInt     @map("cycle_id")
  cycle     AuditCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  auditorId BigInt     @map("auditor_id")
  auditor   Employee   @relation(fields: [auditorId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz

  @@map("audit_assignment")
}

model AuditResult {
  id        BigInt     @id @default(autoincrement())
  cycleId   BigInt     @map("cycle_id")
  cycle     AuditCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  assetId   BigInt     @map("asset_id")
  asset     Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  auditorId BigInt     @map("auditor_id")
  auditor   Employee   @relation(fields: [auditorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  verdict   String     @db.VarChar(50)
  notes     String?    @db.Text
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz

  @@map("audit_result")
}

model Notification {
  id          BigInt   @id @default(autoincrement())
  recipientId BigInt   @map("recipient_id")
  recipient   Employee @relation(fields: [recipientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  type        String   @db.VarChar(50)
  message     String   @db.Text
  isRead      Boolean  @default(false) @map("is_read")
  refId       BigInt?  @map("ref_id")
  refType     String?  @map("ref_type") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("notification")
}

model ActivityLog {
  id        BigInt    @id @default(autoincrement())
  actorId   BigInt?   @map("actor_id")
  actor     Employee? @relation(fields: [actorId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  action    String    @db.VarChar(100)
  entity    String    @db.VarChar(50)
  entityId  BigInt    @map("entity_id")
  metadata  Json?     @map("metadata")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("activity_log")
}
